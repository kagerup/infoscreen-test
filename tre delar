<!DOCTYPE html>
<html lang="sv">
<head>
<meta charset="UTF-8">
<title>Layout 1181x1080</title>

<style>
    body {
        margin: 0;
        padding: 0;
        background: #eaeaea;
        font-family: Arial, sans-serif;
    }

    /* Hela arbetsytan */
    #canvas {
        width: 1181px;
        height: 1080px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 70% 30%;
        grid-template-rows: 540px 540px;
        background: #ffffff;
    }

    /* Stora vänstra rutan (tar två rader) */
    .left-big {
        grid-row: 1 / 3; /* sträcker sig över båda raderna */
        background-color: #98c1d9; /* ljus blå */
        padding: 20px;
        box-sizing: border-box;
    }

    /* Övre högra rutan */
    .right-top {
        background-color: #e5989b; /* varm rosa */
        padding: 20px;
        box-sizing: border-box;
    }

    /* Nedre högra rutan */
    .right-bottom {
        background-color: #b5e48c; /* ljus grön */
        padding: 20px;
        box-sizing: border-box;
    }
</style>

</head>
<body>

<div id="canvas">
    <div class="left-big">
        <h2>Stor container (70%)</h2>
        <p>Här kan du lägga t.ex. menyer eller större innehåll.</p>
    </div>

    <div class="right-top">
        <h3>Höger topp (30%)</h3>
        <p>Perfekt för t.ex. allergiinformation.</p>
    </div>

    <div class="right-bottom">
        <h3>Höger botten (30%)</h3>
        <p>Här kan du lägga t.ex. svinntext eller kort info.</p>
    </div>
</div>

</body>
</html>
